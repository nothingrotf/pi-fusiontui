{
  "name": "pi-fusiontui",
  "version": "0.1.0",
  "description": "A Droid/Grok-inspired editor + rich statusline for Pi (folder, branch, context, price, model, effort, 5h & weekly usage).",
  "type": "module",
  "license": "MIT",
  "keywords": ["pi-package", "pi-extension", "tui", "statusline", "droid", "grok"],
  "author": "nothingrotf",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nothingrotf/pi-fusiontui.git"
  },
  "homepage": "https://github.com/nothingrotf/pi-fusiontui#readme",
  "bugs": {
    "url": "https://github.com/nothingrotf/pi-fusiontui/issues"
  },
  "files": ["extensions", "themes"],
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "pi:dev": "${PI_BIN:-pi} --no-extensions -e ./extensions/fusion/index.ts",
    "pi:install-local": "${PI_BIN:-pi} install ./ -l",
    "commitlint": "commitlint --edit",
    "prepare": "husky || true"
  },
  "peerDependencies": {
    "@earendil-works/pi-ai": "*",
    "@earendil-works/pi-coding-agent": "*",
    "@earendil-works/pi-tui": "*"
  },
  "pi": {
    "extensions": ["./extensions"],
    "themes": ["./themes"]
  },
  "devDependencies": {
    "@commitlint/cli": "^19.6.1",
    "@commitlint/config-conventional": "^19.6.0",
    "@earendil-works/pi-ai": "^0.79.3",
    "@earendil-works/pi-coding-agent": "^0.79.3",
    "@earendil-works/pi-tui": "^0.79.3",
    "@types/node": "^25.5.2",
    "husky": "^9.1.7",
    "typescript": "^6.0.2"
  }
}
